{
  "name": "mdcz",
  "version": "0.9.2",
  "description": "MDCz workspace",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/ShotHeadman/mdcz",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShotHeadman/mdcz.git"
  },
  "author": {
    "name": "ShotHeadman",
    "email": "123543875+ShotHeadman@users.noreply.github.com"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm dev:webui",
    "dev:webui": "concurrently -n server,web -c cyan,magenta \"pnpm --filter @mdcz/server dev\" \"pnpm --filter @mdcz/web dev\"",
    "dev:desktop": "concurrently -n server,desktop -c cyan,green \"pnpm --filter @mdcz/server dev\" \"pnpm --filter @mdcz/desktop dev\"",
    "build": "pnpm --filter @mdcz/desktop build",
    "build:server": "pnpm --filter @mdcz/server build",
    "build:web": "pnpm --filter @mdcz/web build",
    "build:apps": "pnpm build:server && pnpm build:web",
    "build:win": "pnpm --filter @mdcz/desktop build:win",
    "build:mac": "pnpm --filter @mdcz/desktop build:mac",
    "build:linux": "pnpm --filter @mdcz/desktop build:linux",
    "test": "vitest run --silent",
    "test:apps": "pnpm --filter @mdcz/server test && pnpm --filter @mdcz/web test",
    "test:main": "vitest run --project unit",
    "typecheck": "concurrently \"tsc --noEmit -p tsconfig.node.json\" \"tsc --noEmit -p tsconfig.web.json\" \"tsc --noEmit -p tsconfig.test.json\"",
    "typecheck:apps": "pnpm --filter @mdcz/server typecheck && pnpm --filter @mdcz/web typecheck",
    "format": "biome check --write",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@types/node": "^24.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^39.5.2",
    "electron-vite": "^5.0.0",
    "lint-staged": "^16.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "pnpm exec biome check --write --no-errors-on-unmatched"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "impit",
      "sharp",
      "simple-git-hooks"
    ]
  }
}
