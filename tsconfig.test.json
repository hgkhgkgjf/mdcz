{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "electron-vite/node", "vitest/globals"]
  },
  "include": [
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "apps/desktop/src/main/**/*.ts",
    "apps/desktop/src/preload/**/*.ts",
    "apps/desktop/src/renderer/src/**/*.ts",
    "apps/desktop/src/renderer/src/**/*.tsx",
    "apps/desktop/src/**/*.d.ts",
    "apps/server/src/**/*.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "packages/**/*.ts",
    "packages/ui/src/**/*.tsx",
    "vitest.config.ts"
  ]
}
