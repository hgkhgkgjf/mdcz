{
  "files": [],
  "references": [
    { "path": "./tsconfig.node.json" },
    { "path": "./tsconfig.web.json" },
    { "path": "./tsconfig.test.json" }
  ],
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "useDefineForClassFields": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/desktop/src/renderer/src/*"],
      "@main/*": ["apps/desktop/src/main/*"],
      "@renderer/*": ["apps/desktop/src/renderer/src/*"],
      "@mdcz/persistence": ["packages/persistence/src/index.ts"],
      "@mdcz/persistence/test": ["packages/persistence/src/testDatabase.ts"],
      "@mdcz/runtime": ["packages/runtime/src/index.ts"],
      "@mdcz/runtime/*": ["packages/runtime/src/*"],
      "@mdcz/shared": ["packages/shared/index.ts"],
      "@mdcz/shared/*": ["packages/shared/*"],
      "@mdcz/storage": ["packages/storage/src/index.ts"],
      "@mdcz/ui": ["packages/ui/src/index.ts"],
      "@mdcz/ui/*": ["packages/ui/src/*"]
    }
  }
}
